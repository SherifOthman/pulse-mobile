{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "expo": {
      "type": "remote",
      "url": "https://mcp.expo.dev/mcp",
      "headers": {
        "Authorization": "Bearer ${EXPO_ACCESS_TOKEN}"
      }
    },
    "heroui-native": {
      "command": "npx",
      "args": ["-y", "@heroui/native-mcp@latest"]
    }
  }
}
